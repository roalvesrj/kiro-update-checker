{
  "name": "kiro-update-checker",
  "displayName": "Kiro Update Checker",
  "description": "Automatically checks the official Kiro downloads page for new IDE releases. Intended for users running Kiro in Administrator mode, where the built-in update feature may not be available.",
  "version": "0.2.2",
  "icon": "images/KUC-logo.png",
  "publisher": "roalvesrj",
  "repository": {
    "type": "git",
    "url": "https://github.com/roalvesrj/kiro-update-checker.git"
  },
  "author": {
    "name": "Rômulo Alves",
    "email": "romulo@cabiros.com.br"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kiro-update-checker.checkNow",
        "title": "%kiro-update-checker.checkNow.title%"
      }
    ],
    "configuration": {
      "title": "%kiroUpdateChecker.config.title%",
      "properties": {
        "kiroUpdateChecker.checkInterval": {
          "type": "number",
          "default": 60,
          "description": "%kiroUpdateChecker.checkInterval.description%"
        },
        "kiroUpdateChecker.enableOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "%kiroUpdateChecker.enableOnStartup.description%"
        },
        "kiroUpdateChecker.autoDownload": {
          "type": "boolean",
          "default": false,
          "description": "%kiroUpdateChecker.autoDownload.description%"
        },
		"kiroUpdateChecker.downloadFolder": {
		  "type": "string",
		  "default": "",
		  "description": "%kiroUpdateChecker.downloadFolder.description%"
		},
		"kiroUpdateChecker.packageFormat": {
		  "type": "string",
		  "default": "auto",
		  "description": "%kiroUpdateChecker.packageFormat.description%",
		  "enum": [
		    "auto",
		    "deb",
		    "tar.gz",
		    "AppImage",
		    "dmg",
		    "exe"
		  ],
		  "enumDescriptions": [
		    "%kiroUpdateChecker.packageFormat.enumAuto%",
		    "%kiroUpdateChecker.packageFormat.enumDeb%",
		    "%kiroUpdateChecker.packageFormat.enumTarGz%",
		    "%kiroUpdateChecker.packageFormat.enumAppImage%",
		    "%kiroUpdateChecker.packageFormat.enumDmg%",
		    "%kiroUpdateChecker.packageFormat.enumExe%"
		  ]
		}
	      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "~1.75.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "dependencies": {},
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}